{
  "name": "brandloom",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @brandloom/api --filter @brandloom/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "release:validate": "node scripts/validate-release.mjs",
    "release:manifest": "node scripts/create-release-manifest.mjs",
    "activation:validate": "node scripts/validate-activation-config.mjs",
    "activation:smoke": "node scripts/smoke-environment.mjs",
    "security:check": "node scripts/security-static-check.mjs",
    "beta:manifest": "node scripts/create-beta-qa-manifest.mjs",
    "check": "pnpm release:validate && pnpm security:check && pnpm typecheck && pnpm test && pnpm build"
  }
}
