SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=YOUR_SUPPORTED_MODEL_ID
WEB_ORIGIN=http://localhost:5173

# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=BASE64_ENCODED_32_BYTE_KEY
CRON_SECRET=LONG_RANDOM_INTERNAL_DISPATCH_SECRET

# Safe local mode exercises the full publishing state machine without touching Meta.
PUBLISHING_PROVIDER_MODE=mock

# Required when PUBLISHING_PROVIDER_MODE=meta
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8787/integrations/meta/callback
META_OAUTH_AUTHORIZE_URL=https://www.instagram.com/oauth/authorize
META_OAUTH_TOKEN_URL=https://api.instagram.com/oauth/access_token
META_LONG_LIVED_TOKEN_URL=https://graph.instagram.com/access_token
META_REFRESH_TOKEN_URL=https://graph.instagram.com/refresh_access_token
META_GRAPH_BASE_URL=https://graph.instagram.com
META_REQUIRED_SCOPES=instagram_business_basic,instagram_business_content_publish
META_OAUTH_USE_PKCE=true
META_WEBHOOK_VERIFY_TOKEN=LONG_RANDOM_WEBHOOK_VERIFY_TOKEN
