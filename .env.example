# Shared Supabase project values
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# API-only model configuration. Never expose keys to the browser.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=YOUR_SUPPORTED_MODEL_ID
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
WEB_ORIGIN=http://localhost:5173
PUBLIC_API_ORIGIN=http://localhost:8787
BETA_APP_ORIGIN=http://localhost:5173

# Credential custody, rate limiting and internal dispatch
TOKEN_ENCRYPTION_KEY=BASE64_ENCODED_32_BYTE_KEY
RATE_LIMIT_SALT=LONG_RANDOM_RATE_LIMIT_HASH_SALT
CRON_SECRET=LONG_RANDOM_INTERNAL_DISPATCH_SECRET
PUBLISHING_PROVIDER_MODE=mock
BILLING_PROVIDER_MODE=mock
DEPLOYMENT_ENVIRONMENT=local
APP_VERSION=development
COMMIT_SHA=local
EXPECTED_MIGRATION_VERSION=0019

# Stripe values are required only when BILLING_PROVIDER_MODE=stripe.
# Staging uses sk_test_*; production uses sk_live_*.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_API_VERSION=
STRIPE_SUCCESS_URL=http://localhost:5173/#commercial?checkout=success
STRIPE_CANCEL_URL=http://localhost:5173/#commercial?checkout=cancelled

# Meta values are required when PUBLISHING_PROVIDER_MODE=meta.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8787/integrations/meta/callback
META_OAUTH_AUTHORIZE_URL=https://www.instagram.com/oauth/authorize
META_OAUTH_TOKEN_URL=https://api.instagram.com/oauth/access_token
META_LONG_LIVED_TOKEN_URL=https://graph.instagram.com/access_token
META_REFRESH_TOKEN_URL=https://graph.instagram.com/refresh_access_token
META_GRAPH_BASE_URL=https://graph.instagram.com
META_REQUIRED_SCOPES=instagram_business_basic,instagram_business_content_publish
META_OAUTH_USE_PKCE=true
META_WEBHOOK_VERIFY_TOKEN=

# GitHub environment deployment values
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=
CLOUDFLARE_PAGES_BRANCH=
